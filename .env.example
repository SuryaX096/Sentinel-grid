# SentinelMind AI Platform - Environment Configuration Template

# Gemini LLM API Key (Optional: enables advanced threat intelligence and explanation validation)
# Obtain a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Microservices Host & Ports Configuration
HERO_AGENT_HOST=127.0.0.1
HERO_AGENT_PORT=8001

ATTRIBUTION_AGENT_HOST=127.0.0.1
ATTRIBUTION_AGENT_PORT=8002

SUPPORTING_AGENT_HOST=127.0.0.1
SUPPORTING_AGENT_PORT=8003

DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8501

# SQLite Database File Path
DB_PATH=alerts.db
